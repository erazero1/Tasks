<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/userListFragment">

    <fragment
        android:id="@+id/userListFragment"
        android:name="com.erazero1.tasks.ui.userList.UserListFragment"
        android:label="@string/users"
        tools:layout="@layout/fragment_user_list">
        <action
            android:id="@+id/action_userListFragment_to_userDetailsFragment"
            app:destination="@id/userDetailsFragment" />
    </fragment>

    <fragment
        android:id="@+id/userDetailsFragment"
        android:name="com.erazero1.tasks.ui.userDetails.UserDetailsFragment"
        android:label="@string/user_details"
        tools:layout="@layout/fragment_user_details">

        <argument
            android:name="user"
            app:argType="com.erazero1.tasks.domain.model.User" />

        <action
            android:id="@+id/action_userDetailsFragment_to_todoListFragment"
            app:destination="@id/todoListFragment"/>
    </fragment>

    <fragment
        android:id="@+id/todoListFragment"
        android:name="com.erazero1.tasks.ui.todoList.TodoListFragment"
        android:label="@string/tasks"
        tools:layout="@layout/fragment_todo_list">

        <argument
            android:name="userId"
            app:argType="integer" />
        <argument
            android:name="userName"
            app:argType="string" />
    </fragment>

</navigation>